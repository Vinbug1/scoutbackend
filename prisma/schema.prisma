datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  PLAYER
  SCOUT
  ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ParticipantStatus {
  ACTIVE
  COMPLETED
  DROPPED
  PAUSED
}

enum Recommendation {
  RECOMMEND_FOR_TRIAL
  FILE_FOR_FUTURE_REFERENCE
  NOT_SUITABLE
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ChatRoomType {
  DIRECT
  GROUP
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullname  String
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())

  // OTP Verification
  otp        String?
  otpExpiry  DateTime?
  isVerified Boolean   @default(false)

  // Relations
  profile           Profile?
  scoutProfile      ScoutProfile?
  videos            Video[]
  reels             Reel[]
  views             VideoView[]
  reelViews         ReelView[]
  comments          Comment[]
  replies           Reply[]
  ratings           Rating[]
  followers         Follower[]             @relation("Followed")
  following         Follower[]             @relation("Following")
  posts             Post[]

  // ✅ Like relations
  commentLikes      CommentLike[]
  reelLikes         ReelLike[]
  replyLikes        ReplyLike[]

  // Scout reports
  reportsFiled      ScouterReport[]        @relation("ReportsByScouter")
  reportsAboutMe    ScouterReport[]        @relation("ReportsAboutPlayer")
  createdChatRooms ChatRoom[] @relation("ChatRoomCreator")
  payments          Payment[]
  rankings          Ranking[]
  chatMessages      ChatMessage[]
  chatRoomMembers   ChatRoomMember[]
  challengesCreated Challenge[]            @relation("ChallengeCreator")
  challengesJoined  ChallengeParticipant[]

  pushToken   String?
  isOnline    Boolean   @default(false)
  lastSeenAt  DateTime?
  blocksMade  Block[]   @relation("BlockedBy")
  blocksTaken Block[]   @relation("BlockedUser")
  reportsMade Report[]  @relation("ReportedBy")
   messageReads     MessageRead[]
  reportsAgainstMe Report[]        @relation("ReportedUser")
}

// ─────────────────────────────────────────────
// Profiles
// ─────────────────────────────────────────────

model Profile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  avatarUrl     String?
  position      String?
  height        Float?
  favouriteFoot String?
  strengths     String?
  gender        String?
  country       String?
  city          String?
  dob           DateTime?
  bio           String?
  createdAt     DateTime  @default(now())
}

model ScoutProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  avatarUrl String?
  club      String?
  country   String?
  city      String?
  address   String?
  bio       String?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// Scouter Report
// ─────────────────────────────────────────────

model ScouterReport {
  id        Int      @id @default(autoincrement())
  scouterId Int
  playerId  Int
  createdAt DateTime @default(now())

  // 1. Match Info
  matchScouted String?
  ageGroup     String?
  timesSeen    Int?
  currentClub  String?

  // 2. Overall Assessment
  overallAssessment String?

  // 3A. Technical Attributes (1–10)
  firstTouch   Int?
  ballControl  Int?
  dribbling    Int?
  passingShort Int?
  passingLong  Int?
  throughBalls Int?
  smartPass    Int?
  shooting     Int?
  heading      Int?
  tackling     Int?
  weakerFoot   Int?

  // 3B. Tactical Attributes (1–10)
  positionalAwareness Int?
  decisionMaking      Int?
  movementOffBall     Int?
  gameIntelligence    Int?
  transitions         Int?

  // 3C. Physical Attributes (1–10)
  pace            Int?
  agilityBalance  Int?
  strength        Int?
  staminaWorkRate Int?
  jumpingRate     Int?

  // 3D. Psychological Attributes (1–10)
  composure               Int?
  braveryCommitment       Int?
  determination           Int?
  leadershipCommunication Int?
  coachability            Int?

  // 4 & 5. Summaries
  keyStrengths        String[]
  areasForDevelopment String[]

  // 6. Final Recommendation
  recommendation Recommendation?

  scouter User @relation("ReportsByScouter", fields: [scouterId], references: [id])
  player  User @relation("ReportsAboutPlayer", fields: [playerId], references: [id])

  @@index([playerId])
  @@index([scouterId])
}

// ─────────────────────────────────────────────
// Video & Reel
// ─────────────────────────────────────────────

model VideoCategory {
  id    Int    @id @default(autoincrement())
  title String
  reels Reel[]
}

model Video {
  id           Int      @id @default(autoincrement())
  videoUrl     String
  thumbnailUrl String?
  title        String
  description  String?
  published    Boolean  @default(false)
  durationSec  Int?
  createdAt    DateTime @default(now())
  status       String   @default("processing")

  playerId Int
  player   User @relation(fields: [playerId], references: [id])

  views    VideoView[]
  comments Comment[]
  ratings  Rating[]

  @@index([playerId])
  @@index([createdAt])
}

model Reel {
  id           Int      @id @default(autoincrement())
  videoUrl     String
  thumbnailUrl String?
  title        String
  description  String?
  published    Boolean  @default(false)
  durationSec  Int?
  createdAt    DateTime @default(now())
  status       String   @default("processing")

  categoryId Int
  category   VideoCategory @relation(fields: [categoryId], references: [id])

  playerId Int
  player   User @relation(fields: [playerId], references: [id])

  views    ReelView[]
  comments Comment[]
  ratings  Rating[]

  // ✅ Added
  likes    ReelLike[]

  @@index([playerId])
  @@index([createdAt])
  @@index([categoryId])
}

// ─────────────────────────────────────────────
// Views
// ─────────────────────────────────────────────

model VideoView {
  id       Int      @id @default(autoincrement())
  videoId  Int
  userId   Int?
  ipHash   String?
  viewedAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@unique([videoId, userId], name: "unique_view_per_user")
  @@index([videoId])
  @@index([userId])
}

model ReelView {
  id       Int      @id @default(autoincrement())
  reelId   Int
  userId   Int?
  ipHash   String?
  viewedAt DateTime @default(now())

  reel Reel  @relation(fields: [reelId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([reelId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Comments, Replies & Likes
// ─────────────────────────────────────────────

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  videoId Int?
  postId  Int?
  reelId  Int?
  userId  Int

  video   Video?  @relation(fields: [videoId], references: [id])
  post    Post?   @relation(fields: [postId], references: [id])
  reel    Reel?   @relation(fields: [reelId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  replies Reply[]

  // ✅ Added
  likes   CommentLike[]

  @@index([videoId])
  @@index([postId])
  @@index([reelId])
}

model CommentLike {
  id        Int @id @default(autoincrement())
  commentId Int
  userId    Int

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model Reply {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  commentId Int
  userId    Int

  comment Comment    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id])

  // ✅ Added
  likes   ReplyLike[]

  @@index([commentId])
  @@index([userId])
}

model ReplyLike {
  id      Int @id @default(autoincrement())
  replyId Int
  userId  Int

  reply Reply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, userId])
  @@index([replyId])
  @@index([userId])
}

model ReelLike {
  id     Int @id @default(autoincrement())
  reelId Int
  userId Int

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
  @@index([reelId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Ratings & Rankings
// ─────────────────────────────────────────────

model Rating {
  id        Int      @id @default(autoincrement())
  score     Int
  createdAt DateTime @default(now())

  videoId Int?
  reelId  Int?
  userId  Int

  video Video? @relation(fields: [videoId], references: [id])
  reel  Reel?  @relation(fields: [reelId], references: [id])
  user  User   @relation(fields: [userId], references: [id])

  @@unique([videoId, userId])
  @@unique([reelId, userId])
  @@index([videoId])
  @@index([reelId])
}

model Ranking {
  id        Int      @id @default(autoincrement())
  userId    Int
  score     Float    @default(0)
  reason    String?
  updatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId])
  @@index([score])
}

// ─────────────────────────────────────────────
// Posts
// ─────────────────────────────────────────────

model Post {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  userId    Int

  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]
}

// ─────────────────────────────────────────────
// Followers
// ─────────────────────────────────────────────

model Follower {
  id         Int      @id @default(autoincrement())
  followerId Int
  followedId Int
  followedAt DateTime @default(now())

  follower User @relation("Following", fields: [followerId], references: [id])
  followed User @relation("Followed", fields: [followedId], references: [id])

  @@unique([followerId, followedId])
  @@index([followedId])
  @@index([followerId])
}

// ─────────────────────────────────────────────
// Payments
// ─────────────────────────────────────────────

model Payment {
  id          Int           @id @default(autoincrement())
  userId      Int
  amount      Float
  currency    String        @default("USD")
  status      PaymentStatus @default(PENDING)
  providerRef String?
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────
// Challenges
// ─────────────────────────────────────────────

model Challenge {
  id             Int       @id @default(autoincrement())
  videoUrl       String
  thumbnailUrl   String?
  title          String
  description    String?
  startAt        DateTime?
  endAt          DateTime?
  createdAt      DateTime  @default(now())
  targetProgress Float     @default(100)

  creatorId Int
  creator   User @relation("ChallengeCreator", fields: [creatorId], references: [id])

  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id          Int               @id @default(autoincrement())
  challengeId Int
  userId      Int
  joinedAt    DateTime          @default(now())
  completedAt DateTime?
  progress    Float             @default(0)
  status      ParticipantStatus @default(ACTIVE)

  challenge Challenge @relation(fields: [challengeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  progressLogs ProgressLog[]

  @@unique([challengeId, userId])
  @@index([status])
  @@index([progress])
}

model ProgressLog {
  id            Int      @id @default(autoincrement())
  participantId Int
  taskId        Int?
  description   String
  progressDelta Float
  createdAt     DateTime @default(now())

  participant ChallengeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Chat
// ─────────────────────────────────────────────


model ChatRoom {
  id    Int          @id @default(autoincrement())
  type  ChatRoomType @default(DIRECT)
  name  String?

  creatorId Int?
  creator   User? @relation("ChatRoomCreator", fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastMessageId Int?         @unique
  lastMessage   ChatMessage? @relation("LastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)

  directKey String? @unique   // ← new: dedup key for DIRECT rooms

  messages ChatMessage[]    @relation("RoomMessages")
  members  ChatRoomMember[]

  @@index([type])
  @@index([updatedAt])
}

model ChatRoomMember {
  id                Int       @id @default(autoincrement())

  roomId            Int
  userId            Int

  joinedAt          DateTime  @default(now())

  unreadCount       Int       @default(0)

  lastReadMessageId Int?

  isBlockedByPeer   Boolean   @default(false)

  room              ChatRoom  @relation(fields: [roomId], references: [id])
  user              User      @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])

  @@index([roomId])
  @@index([userId])
}

model ChatMessage {
  id            Int           @id @default(autoincrement())

  roomId        Int
  userId        Int

  clientTempId  String?       @unique

  type          MessageType   @default(TEXT)

  text          String?

  mediaUrl      String?
  thumbnailUrl  String?

  fileName      String?
  fileSize      Int?
  durationSec   Int?

  status        MessageStatus @default(SENT)

  sentAt        DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  editedAt      DateTime?
  deletedAt     DateTime?

  room          ChatRoom      @relation("RoomMessages", fields: [roomId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  roomAsLast    ChatRoom?     @relation("LastMessage")

  replyToId     Int?
  replyTo       ChatMessage?  @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       ChatMessage[] @relation("MessageReply")

  reads         MessageRead[]
  reports       Report[]

  @@index([roomId, sentAt])
  @@index([roomId, status])
  @@index([replyToId])
  @@index([status])
  @@index([userId])

}

model MessageRead {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  readAt    DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model Block {
  id          Int      @id @default(autoincrement())
  blockerId   Int
  blockedId   Int
  createdAt   DateTime @default(now())

  blocker User @relation("BlockedBy", fields: [blockerId], references: [id])
  blocked User @relation("BlockedUser", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  reportedId Int
  messageId  Int?
  reason     String
  createdAt  DateTime @default(now())

  reporter User         @relation("ReportedBy", fields: [reporterId], references: [id])
  reported User         @relation("ReportedUser", fields: [reportedId], references: [id])
  message  ChatMessage? @relation(fields: [messageId], references: [id])

  @@index([reportedId])
}