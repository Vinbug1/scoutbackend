datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PLAYER
  SCOUT
  ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ParticipantStatus {
  ACTIVE
  COMPLETED
  DROPPED
  PAUSED
}

enum Recommendation {
  RECOMMEND_FOR_TRIAL
  FILE_FOR_FUTURE_REFERENCE
  NOT_SUITABLE
}

model ScouterReport {
  id        Int      @id @default(autoincrement())
  scouterId Int
  playerId  Int
  createdAt DateTime @default(now())

  // 1. Match Info (snapshot at time of scouting)
  matchScouted String?
  ageGroup     String?
  timesSeen    Int?
  currentClub  String?

  // 2. Scout's Overall Assessment
  overallAssessment String?

  // 3A. Technical Attributes (1–10)
  firstTouch   Int?
  ballControl  Int?
  dribbling    Int?
  passingShort Int?
  passingLong  Int?
  throughBalls Int?
  smartPass    Int?
  shooting     Int?
  heading      Int?
  tackling     Int?
  weakerFoot   Int?

  // 3B. Tactical Attributes (1–10)
  positionalAwareness Int?
  decisionMaking      Int?
  movementOffBall     Int?
  gameIntelligence    Int?
  transitions         Int?

  // 3C. Physical Attributes (1–10)
  pace            Int?
  agilityBalance  Int?
  strength        Int?
  staminaWorkRate Int?
  jumpingRate     Int?

  // 3D. Psychological Attributes (1–10)
  composure               Int?
  braveryCommitment       Int?
  determination           Int?
  leadershipCommunication Int?
  coachability            Int?

  // 4 & 5. Summaries
  keyStrengths        String[]
  areasForDevelopment String[]

  // 6. Final Recommendation
  recommendation Recommendation?

  scouter User @relation("ReportsByScouter", fields: [scouterId], references: [id])
  player  User @relation("ReportsAboutPlayer", fields: [playerId], references: [id])

  @@index([playerId])
  @@index([scouterId])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullname  String
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())

  // OTP Verification fields
  otp        String?
  otpExpiry  DateTime?
  isVerified Boolean   @default(false)

  profile           Profile?
  scoutProfile      ScoutProfile?
  videos            Video[]
  views             VideoView[]
  comments          Comment[]
  ratings           Rating[]
  followers         Follower[]             @relation("Followed")
  following         Follower[]             @relation("Following")
  posts             Post[]

  // Scouter only: reports written by this user
  reportsFiled      ScouterReport[]        @relation("ReportsByScouter")

  // Player only: reports written about this user
  reportsAboutMe    ScouterReport[]        @relation("ReportsAboutPlayer")

  payments          Payment[]
  rankings          Ranking[]
  chatMessages      ChatMessage[]
  chatRoomMembers   ChatRoomMember[]
  challengesCreated Challenge[]            @relation("ChallengeCreator")
  challengesJoined  ChallengeParticipant[]
}

model Profile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  avatarUrl     String?
  position      String?
  height        Float?
  favouriteFoot String?
  strengths     String?
  gender        String?
  country       String?
  city          String?
  dob           DateTime?
  bio           String?
  createdAt     DateTime  @default(now())
}

model ScoutProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  avatarUrl String?
  club      String?
  country   String?
  city      String?
  address   String?
  bio       String?
  createdAt DateTime @default(now())
}

enum CategoryType {
  SKILL
  GENERAL
  TACTICAL
  PHYSICAL
}

model VideoCategory {
  id           Int          @id @default(autoincrement())
  title        String
  categoryType CategoryType @default(GENERAL)
  videos       Video[]
}

model Video {
  id           Int      @id @default(autoincrement())
  videoUrl     String
  thumbnailUrl String?
  title        String
  description  String?
  published    Boolean  @default(false)
  durationSec  Int?
  createdAt    DateTime @default(now())
  status       String   @default("processing")

  categoryId Int?
  category   VideoCategory? @relation(fields: [categoryId], references: [id])

  playerId Int
  player   User @relation(fields: [playerId], references: [id])

  views    VideoView[]
  comments Comment[]
  ratings  Rating[]

  @@index([playerId])
  @@index([createdAt])
  @@index([categoryId])
}

model VideoView {
  id       Int      @id @default(autoincrement())
  videoId  Int
  userId   Int?
  ipHash   String?
  viewedAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@unique([videoId, userId], name: "unique_view_per_user")
  @@index([videoId])
  @@index([userId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  videoId Int?
  postId  Int?
  userId  Int

  video Video? @relation(fields: [videoId], references: [id])
  post  Post?  @relation(fields: [postId], references: [id])
  user  User   @relation(fields: [userId], references: [id])

  @@index([videoId])
  @@index([postId])
}

model Rating {
  id        Int      @id @default(autoincrement())
  score     Int
  createdAt DateTime @default(now())

  videoId Int
  userId  Int

  video Video @relation(fields: [videoId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([videoId, userId])
  @@index([videoId])
}

model Ranking {
  id        Int      @id @default(autoincrement())
  userId    Int
  score     Float    @default(0)
  reason    String?
  updatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId])
  @@index([score])
}

model Challenge {
  id             Int       @id @default(autoincrement())
  videoUrl     String   // master.m3u8 — adaptive HLS master playlist
  thumbnailUrl String?
  title          String
  description    String?
  startAt        DateTime?
  endAt          DateTime?
  createdAt      DateTime  @default(now())
  targetProgress Float     @default(100)

  creatorId Int
  creator   User @relation("ChallengeCreator", fields: [creatorId], references: [id])

  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id          Int               @id @default(autoincrement())
  challengeId Int
  userId      Int
  joinedAt    DateTime          @default(now())
  completedAt DateTime?
  progress    Float             @default(0)
  status      ParticipantStatus @default(ACTIVE)

  challenge Challenge @relation(fields: [challengeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  progressLogs ProgressLog[]

  @@unique([challengeId, userId])
  @@index([status])
  @@index([progress])
}

model ProgressLog {
  id            Int      @id @default(autoincrement())
  participantId Int
  taskId        Int?
  description   String
  progressDelta Float
  createdAt     DateTime @default(now())

  participant ChallengeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

model ChatRoom {
  id        Int              @id @default(autoincrement())
  name      String?
  createdAt DateTime         @default(now())
  messages  ChatMessage[]
  members   ChatRoomMember[] // 👈 add this
}

model ChatMessage {
  id      Int      @id @default(autoincrement())
  roomId  Int
  userId  Int
  message String
  sentAt  DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id])
  user User     @relation(fields: [userId], references: [id])

  @@index([roomId])
  @@index([userId])
}

model ChatRoomMember {
  id       Int      @id @default(autoincrement())
  roomId   Int
  userId   Int
  joinedAt DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id])
  user User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

model Post {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  userId    Int

  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]
}

model Follower {
  id         Int      @id @default(autoincrement())
  followerId Int
  followedId Int
  followedAt DateTime @default(now())

  follower User @relation("Following", fields: [followerId], references: [id])
  followed User @relation("Followed", fields: [followedId], references: [id])

  @@unique([followerId, followedId])
  @@index([followedId])
  @@index([followerId])
}


model Payment {
  id          Int           @id @default(autoincrement())
  userId      Int
  amount      Float
  currency    String        @default("USD")
  status      PaymentStatus @default(PENDING)
  providerRef String?
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}
